{
  "name": "@codecomply/db",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "import": "./dist/client.js",
      "types": "./dist/client.d.ts"
    }
  },
  "scripts": {
    "postinstall": "prisma generate",
    "build": "prisma generate && tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "clean": "rm -rf dist",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev --name auto-migration",
    "db:migrate:create": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "generate": "prisma generate",
    "migrate": "prisma migrate deploy",
    "migrate:deploy": "prisma migrate deploy",
    "seed": "tsx prisma/seed.ts",
    "typecheck": "tsc --noEmit",
    "test": "prisma generate && vitest run",
    "test:unit": "prisma generate && vitest run __tests__/unit",
    "test:integration": "prisma generate && vitest run __tests__/integration",
    "test:coverage": "prisma generate && vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcrypt": "^6.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^20.9.0",
    "@vitest/coverage-v8": "^1.6.1",
    "prisma": "^5.22.0",
    "tsx": "^4.6.2",
    "vitest": "^1.0.4"
  }
}
