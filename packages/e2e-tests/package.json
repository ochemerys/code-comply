{
  "name": "@codecomply/e2e-tests",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "echo 'E2E tests must be run via Docker (pnpm test:e2e) or locally (pnpm --filter @codecomply/e2e-tests test:local)' && exit 0",
    "test:docker": "NODE_OPTIONS='--import tsx --no-warnings' cucumber-js --config cucumber.cjs",
    "test:local": "node scripts/run-with-servers.cjs",
    "test:local:debug": "DEBUG=1 node scripts/run-with-servers.cjs",
    "test:inspector": "NODE_OPTIONS='--import tsx --no-warnings' cucumber-js --config cucumber.cjs features/inspector/**/*.feature",
    "test:checklists": "NODE_OPTIONS='--import tsx --no-warnings' cucumber-js --config cucumber.cjs features/checklists/**/*.feature",
    "test:admin": "NODE_OPTIONS='--import tsx --no-warnings' cucumber-js --config cucumber.cjs features/admin/**/*.feature",
    "test:api": "NODE_OPTIONS='--import tsx --no-warnings' cucumber-js --config cucumber.cjs features/api/**/*.feature",
    "test:workflows": "NODE_OPTIONS='--import tsx --no-warnings' cucumber-js --config cucumber.cjs features/workflows/**/*.feature",
    "test:database": "NODE_OPTIONS='--import tsx --no-warnings' cucumber-js --config cucumber.cjs features/database/checklist-service.feature features/database/checklist-schema.feature features/database/code-library-service.feature features/database/checklist-api-routes.feature features/database/deficiency-schema.feature features/database/deficiency-service.feature features/database/deficiency-http-routes.feature features/database/document-service.feature features/database/document-api-routes.feature features/database/pdf-generation.feature features/database/report-templates.feature features/database/report-model.feature features/database/voc-model.feature features/database/voc-service.feature features/database/addendum-model.feature features/database/append-only-inspection.feature features/database/photo-api-routes.feature features/database/photo-schema.feature features/validators/deficiency-dto-contract.feature",
    "test:deficiencies": "NODE_OPTIONS='--import tsx --no-warnings' cucumber-js --config cucumber.cjs features/deficiencies/**/*.feature",
    "test:report": "NODE_OPTIONS='--import tsx --no-warnings' cucumber-js --config cucumber.cjs --format html:reports/cucumber-report.html",
    "test:critical-journeys": "NODE_OPTIONS='--import tsx --no-warnings' cucumber-js --config cucumber.cjs --tags '@M11-S16' features/workflows/critical-user-journeys.feature",
    "test:ipad-devices": "NODE_OPTIONS='--import tsx --no-warnings' cucumber-js --config cucumber.cjs --tags '@M11-S17' features/inspector/ipad-device-testing.feature",
    "test:accessibility-audit": "NODE_OPTIONS='--import tsx --no-warnings' cucumber-js --config cucumber.cjs --tags '@M11-S18' features/inspector/accessibility-audit.feature",
    "test:ci-pipeline": "NODE_OPTIONS='--import tsx --no-warnings' cucumber-js --config cucumber.cjs --tags '@M11-S19' features/ci/ci-pipeline.feature",
    "test:monitoring": "NODE_OPTIONS='--import tsx --no-warnings' cucumber-js --config cucumber.cjs --tags '@M11-S20' features/ci/monitoring.feature",
    "test:backups": "NODE_OPTIONS='--import tsx --no-warnings' cucumber-js --config cucumber.cjs --tags '@M11-S21' features/ci/backups.feature",
    "test:api-docs": "NODE_OPTIONS='--import tsx --no-warnings' cucumber-js --config cucumber.cjs --tags '@M11-S22' features/ci/api-documentation.feature",
    "test:user-guides": "NODE_OPTIONS='--import tsx --no-warnings' cucumber-js --config cucumber.cjs --tags '@M11-S23' features/ci/user-guides.feature",
    "test:operations-runbook": "NODE_OPTIONS='--import tsx --no-warnings' cucumber-js --config cucumber.cjs --tags '@M11-S24' features/ci/operations-runbook.feature",
    "capture:user-guide-screenshots": "node scripts/capture-user-guide-screenshots.mjs",
    "capture:user-manual-screenshots": "node scripts/capture-user-manual-screenshots.mjs"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@codecomply/db": "workspace:*",
    "@codecomply/validators": "workspace:*",
    "@cucumber/cucumber": "^10.0.1",
    "@playwright/test": "^1.40.0",
    "@prisma/client": "^5.6.0",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^20.9.0",
    "bcrypt": "^6.0.0",
    "hono": "^4.11.9",
    "playwright": "^1.40.0",
    "ts-node": "^10.9.1",
    "tsx": "^4.7.0",
    "typescript": "^5.2.2",
    "wait-on": "^7.2.0"
  }
}
