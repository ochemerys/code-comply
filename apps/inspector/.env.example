# API Base URL
# Optional. Leave unset (or keep the default below) so the Inspector dev server proxies /auth and /api to port 4000.
# Local development: http://localhost:4000
# Staging: https://api-staging.example.com
# Production: https://api.example.com
VITE_API_URL=http://localhost:4000

# Monitoring (M11-S20)
# VITE_SENTRY_DSN="https://xxxxx@o0.ingest.sentry.io/0"
# VITE_APP_ENV=development

# Web Push (NFR-M-04) — public VAPID key only (must match API VAPID_PUBLIC_KEY)
# Generate keys: pnpm --filter @codecomply/api exec web-push generate-vapid-keys
# VITE_VAPID_PUBLIC_KEY="<public-key>"
# Required in dev for push subscribe + notifications:
# VITE_ENABLE_PWA_DEV=true

# Idle auto-logout (M-07) — milliseconds; defaults 14 min warn / 15 min logout
# VITE_IDLE_WARN_MS=840000
# VITE_IDLE_LOGOUT_MS=900000

# Forced re-auth when the app has not been opened within this many days (M-01); default 30
# VITE_MAX_OFFLINE_DAYS=30
