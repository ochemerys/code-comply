{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* Path mapping */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@codecomply/ui": ["../../packages/ui/src/index.ts"]
    },

    /* Composite project */
    "composite": true,
    "types": []
  },
  "include": ["env.d.ts", "src/**/*.ts", "src/**/*.d.ts", "src/**/*.tsx", "src/**/*.vue"],
  "exclude": ["node_modules", "dist", "**/__tests__/*", "**/*.spec.ts", "**/*.test.ts"],
  "references": [
    { "path": "./tsconfig.node.json" },
    { "path": "../api/tsconfig.build.json" },
    { "path": "../../packages/contracts" },
    { "path": "../../packages/ui" },
    { "path": "../../packages/utils" },
    { "path": "../../packages/validators" }
  ]
}
