{
  "name": "@codecomply/inspector",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:push": "VITE_ENABLE_PWA_DEV=true vite",
    "build": "pnpm --filter @codecomply/api... --filter @codecomply/ui... build && vue-tsc -p tsconfig.app.json && vite build",
    "preview": "vite preview",
    "typecheck": "pnpm --filter @codecomply/api... --filter @codecomply/ui... build && vue-tsc -p tsconfig.app.json --noEmit",
    "lint": "pnpm lint:semantic-colors && node scripts/check-modal-overlays.mjs && eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts 2>&1 | grep -v 'WARNING: You are currently running a version of TypeScript'",
    "lint:semantic-colors": "node scripts/check-view-semantic-colors.mjs",
    "lint:fix": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix 2>&1 | grep -v 'WARNING: You are currently running a version of TypeScript'",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@codecomply/contracts": "workspace:*",
    "@codecomply/ui": "workspace:*",
    "@codecomply/utils": "workspace:*",
    "@codecomply/validators": "workspace:*",
    "@sentry/vue": "^10.53.1",
    "@tanstack/vue-query": "^5.8.4",
    "@tanstack/vue-virtual": "^3.13.23",
    "@vueuse/core": "^11.3.0",
    "browser-image-compression": "^2.0.2",
    "crypto-js": "^4.2.0",
    "dexie": "^3.2.4",
    "fabric": "^6.6.1",
    "hono": "^4.11.9",
    "pinia": "^2.1.7",
    "vue": "^3.3.4",
    "vue-router": "^4.2.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@codecomply/api": "workspace:*",
    "@tailwindcss/forms": "^0.5.11",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^20.9.0",
    "@typescript-eslint/eslint-plugin": "^6.11.0",
    "@typescript-eslint/parser": "^6.11.0",
    "@vitejs/plugin-vue": "^4.4.0",
    "@vitest/coverage-v8": "^1.6.1",
    "@vue/test-utils": "^2.4.1",
    "@vue/tsconfig": "^0.4.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.53.0",
    "eslint-plugin-vue": "^9.18.1",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^23.0.1",
    "postcss": "^8.4.31",
    "tailwind-scrollbar-hide": "^4.0.0",
    "tailwindcss": "^3.3.5",
    "vite": "^5.0.0",
    "vite-plugin-pwa": "^0.17.0",
    "vitest": "^1.0.4",
    "vue-tsc": "^3.2.4",
    "workbox-background-sync": "^7.0.0",
    "workbox-cacheable-response": "^7.0.0",
    "workbox-core": "^7.0.0",
    "workbox-expiration": "^7.0.0",
    "workbox-precaching": "^7.0.0",
    "workbox-routing": "^7.0.0",
    "workbox-strategies": "^7.0.0",
    "workbox-window": "^7.0.0"
  }
}
