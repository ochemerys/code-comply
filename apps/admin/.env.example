# API Base URL
# Local development: http://localhost:4000
# Staging: https://api-staging.example.com
# Production: https://api.example.com
VITE_API_URL=http://localhost:4000

# Monitoring (M11-S20)
# VITE_SENTRY_DSN="https://xxxxx@o0.ingest.sentry.io/0"
# VITE_APP_ENV=development

# CSP (NFR-A-01) — extra connect-src origins (space-separated)
# VITE_CSP_CONNECT_SRC="https://cdn.example.com"

# Idle auto-logout (NFR-A-01) — milliseconds until warn dialog / hard logout
# VITE_IDLE_WARN_MS=840000
# VITE_IDLE_LOGOUT_MS=900000
