{
  "name": "@codecomply/admin",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm --filter @codecomply/api build && pnpm --filter @codecomply/validators build && vue-tsc && vite build",
    "preview": "vite preview",
    "typecheck": "pnpm --filter @codecomply/api build && vue-tsc --noEmit",
    "lint": "pnpm lint:semantic-colors && eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts",
    "lint:semantic-colors": "node scripts/check-semantic-colors.mjs",
    "lint:fix": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@codecomply/ui": "workspace:*",
    "@codecomply/utils": "workspace:*",
    "@codecomply/validators": "workspace:*",
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@fullcalendar/vue3": "^6.1.20",
    "@sentry/vue": "^10.53.1",
    "@tanstack/vue-query": "^5.62.8",
    "@vueuse/core": "^11.3.0",
    "@tanstack/vue-table": "^8.20.5",
    "hono": "^4.11.9",
    "pinia": "^2.1.7",
    "vue": "^3.4.0",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@codecomply/api": "workspace:*",
    "@types/node": "^20.9.0",
    "@typescript-eslint/eslint-plugin": "^6.11.0",
    "@typescript-eslint/parser": "^6.11.0",
    "@vitejs/plugin-vue": "^4.4.0",
    "@vitest/coverage-v8": "^1.6.1",
    "@vue/test-utils": "^2.4.1",
    "@vue/tsconfig": "^0.4.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.53.0",
    "eslint-plugin-vue": "^9.18.1",
    "jsdom": "^23.0.1",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "vite": "^5.0.0",
    "vitest": "^1.0.4",
    "vue-tsc": "^3.2.4"
  }
}
