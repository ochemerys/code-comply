# API Configuration
PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# Database
DATABASE_URL="postgresql://inspector:password@localhost:5432/inspections?schema=public"

# Inspector PWA (5174 admin, 5175 inspector — used for SSO redirect URIs)
INSPECTOR_URL=http://localhost:5175
ADMIN_URL=http://localhost:5174

# Inspector SSO / OIDC (M-01) — dev provider enabled by default in development
# SSO_DEV_PROVIDER=true
# SSO_ENABLED=true
# SSO_CLIENT_ID=inspector-pwa
# SSO_REDIRECT_URIS=http://localhost:5175/login/sso-callback
# SSO_ISSUER_URL=https://your-idp.example.com
# SSO_CLIENT_SECRET=
# Comma-separated additional trusted browser origins (no wildcards)
# EXTRA_CORS_ORIGINS=https://preview.example.com,https://partner.example.com

# JWT Authentication (generate with: openssl rand -base64 32)
JWT_SECRET="your-generated-secret-here"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Offline & Security
OFFLINE_GRACE_PERIOD_HOURS="10"
AUTO_LOGOUT_IDLE_MINUTES="30"

# Content Security Policy (M11-S1)
# CSP_REPORT_ONLY="true"   # Report-only mode for testing (default: true in development)
# CSP_REPORT_URI="https://reports.example.com/csp"
# CSP_CONNECT_SRC="https://api.example.com"  # Extra connect-src origins
# API_PUBLIC_URL="https://api.example.com"

# TLS & HSTS (M11-S2) — Render uses automatic TLS at the edge; set in production
# HSTS_ENABLED="true"        # Emit Strict-Transport-Security (default: true in production)
# HSTS_HEADER="max-age=31536000; includeSubDomains; preload"
# TLS_ENFORCE="true"         # Reject non-HTTPS requests (default: true in production)
# TLS_KEY_PATH="/path/to/key.pem"   # Optional direct Node HTTPS (min TLS 1.2)
# TLS_CERT_PATH="/path/to/cert.pem"

# Object storage (Cloudflare R2 in production, MinIO locally — see docker-compose minio service)
# R2_ENDPOINT="http://localhost:9000"
# R2_ACCESS_KEY_ID="minioadmin"
# R2_SECRET_ACCESS_KEY="minioadmin"
# R2_BUCKET_PHOTOS="inspection-photos"
# R2_BUCKET_DOCUMENTS="inspection-documents"
# R2_REGION="auto"
# Set true when using MinIO if path-style is required (defaults true for localhost in code)
# R2_FORCE_PATH_STYLE="true"
# Run API integration tests against MinIO: STORAGE_INTEGRATION_TEST=1 pnpm --filter @codecomply/api test:integration

# Monitoring (M11-S20) — Sentry error tracking and performance traces
# SENTRY_DSN="https://xxxxx@o0.ingest.sentry.io/0"
# SENTRY_ENVIRONMENT="staging"

# Web Push (NFR-M-04) — generate keys: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=""
# VAPID_PRIVATE_KEY=""
# VAPID_SUBJECT="mailto:admin@example.com"

# Database backups (M11-S21) — geo-redundant Cloudflare R2
# R2_BACKUP_BUCKET="inspection-db-backups"
# R2_BACKUP_GEO_BUCKET="inspection-db-backups-geo"
# R2_BACKUP_ENDPOINT="https://<account_id>.r2.cloudflarestorage.com"
# R2_BACKUP_GEO_ENDPOINT="https://<account_id>.r2.cloudflarestorage.com"
# BACKUP_RETENTION_DAYS="30"
