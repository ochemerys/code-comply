{
  "name": "@codecomply/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "types": "./dist/client-app-type.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./app": {
      "types": "./dist/client-app-type.d.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "typecheck": "pnpm --filter @codecomply/db db:generate && tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --exclude '__tests__/integration/**'",
    "test:integration": "vitest run __tests__/integration",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix"
  },
  "dependencies": {
    "@codecomply/db": "workspace:*",
    "@codecomply/validators": "workspace:*",
    "@aws-sdk/client-s3": "^3.741.0",
    "@aws-sdk/s3-request-presigner": "^3.741.0",
    "@hono/node-server": "^1.19.9",
    "@hono/swagger-ui": "^0.5.3",
    "@hono/zod-openapi": "0.16.4",
    "@hono/zod-validator": "^0.1.11",
    "@sendgrid/mail": "^8.1.6",
    "@sentry/node": "^10.53.1",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.6",
    "bcrypt": "^6.0.0",
    "hono": "^4.11.9",
    "ioredis": "^5.6.1",
    "isomorphic-dompurify": "^3.14.0",
    "jsonwebtoken": "^9.0.3",
    "pdfkit": "^0.18.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "validator": "^13.15.35",
    "web-push": "^3.6.7",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@prisma/client": "^5.6.0",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.9.0",
    "@types/validator": "^13.15.10",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^1.6.1",
    "tsx": "^4.6.2",
    "vitest": "^1.0.4",
    "yaml": "^2.9.0"
  }
}
